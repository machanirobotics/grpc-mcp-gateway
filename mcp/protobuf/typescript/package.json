{
	"name": "@machanirobotics/grpc-mcp-gateway-protos",
	"version": "1.0.0",
	"description": "Pre-compiled Protocol Buffer types for grpc-mcp-gateway (mcp.protobuf), generated with protobuf-ts",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/machanirobotics/grpc-mcp-gateway.git",
		"directory": "mcp/protobuf/typescript"
	},
	"keywords": [
		"grpc",
		"mcp",
		"protobuf",
		"model-context-protocol"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./index.ts",
	"types": "./index.ts",
	"exports": {
		".": {
			"types": "./index.ts",
			"import": "./index.ts"
		},
		"./google/protobuf/descriptor": {
			"types": "./lib/google/protobuf/descriptor.ts",
			"import": "./lib/google/protobuf/descriptor.ts",
			"default": "./lib/google/protobuf/descriptor.ts"
		}
	},
	"files": [
		"index.ts",
		"lib/**/*.ts",
		"README.md"
	],
	"scripts": {
		"check": "tsc -p tsconfig.json --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"dependencies": {
		"@protobuf-ts/runtime": "^2.11.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"typescript": "^5.6.0"
	},
	"peerDependencies": {
		"typescript": ">=5.4.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=18"
	}
}
